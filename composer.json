{
    "name": "on2media/oauth2-sso-client",
    "description": "OAuth2 single sign-on client",
    "type": "library",
    "keywords": ["on2 media", "oauth2", "sso", "single sign-on"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "league/oauth2-client": "^2.6.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "autoload": {
        "psr-4": {
            "On2Media\\OAuth2SSOClient\\": "src/"
        }
    },
    "scripts": {
        "phpcs-dry": "php-cs-fixer fix --verbose --allow-risky=yes --dry-run --diff",
        "phpcs-fix": "php-cs-fixer fix --verbose --allow-risky=yes"
    }
}
